# Application Settings
APP_NAME=agentic-rag-pipeline
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# FastAPI Configuration
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_RELOAD=True
FASTAPI_WORKERS=4

# LLM Configuration
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4-turbo
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2048

# Vector Database (Qdrant)
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=documents
QDRANT_VECTOR_SIZE=1536
QDRANT_TIMEOUT=30

# Redis & Celery
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=True

# Observability
PHOENIX_HOST=phoenix
PHOENIX_PORT=6006
ENABLE_PHOENIX_TRACING=True
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Evaluation Thresholds
EVAL_THRESHOLD_CONTEXT_RELEVANCE=0.7
EVAL_THRESHOLD_FAITHFULNESS=0.8
EVAL_THRESHOLD_ANSWER_RELEVANCE=0.75

# Ingestion Parameters
CHUNK_SIZE_CHILD=128
CHUNK_SIZE_PARENT=512
CHUNK_OVERLAP=20
SEMANTIC_CHUNKING_ENABLED=True
SEMANTIC_SIMILARITY_THRESHOLD=0.5

# Retrieval Parameters
RETRIEVAL_TOP_K=5
BM25_WEIGHT=0.4
DENSE_WEIGHT=0.6
RRF_K=60

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=agentic_rag
DB_USER=postgres
DB_PASSWORD=password

# Feature Flags
ENABLE_SELF_CORRECTION=True
ENABLE_INTENT_ROUTING=True
ENABLE_HYBRID_RETRIEVAL=True
ENABLE_STREAMING_RESPONSES=False
